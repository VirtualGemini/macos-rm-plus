#!/bin/sh
# SPDX-License-Identifier: Apache-2.0

set -eu

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

if [ ! -d .build/checkouts/SwiftLint ]; then
  echo "error: development dependencies are not resolved; run 'make bootstrap'" >&2
  exit 1
fi

make format-check
make lint
make lint-scripts
make lint-actions
make check-spdx
make check-dangerous
